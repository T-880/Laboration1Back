# Hostnamnet eller IP-adressen för databasen. 

# Användarnamn för att ansluta till databasen. 
DB_USER=root

# Lösenordet för användaren. Eftersom intget lösenord har angetts lämnas detta tomt 
DB_PASS=       

# Namnet på databasen som applikationen ska ansluta till.
DB_NAME=cv

# Portnumret för databasen. Standardporten för MySQL/MariaDB är 3306
DB_PORT=3306